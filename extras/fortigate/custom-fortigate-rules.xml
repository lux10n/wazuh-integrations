<!-- FORTIGATE V7 // NEW -->
<group name="fortigate,firewall">
  <!-- Traffic logs -->
  <rule id="235001" level="0">
    <if_sid>111145</if_sid>
    <description>FortiGate : Silencing forward traffic logs.</description>
  </rule>
  <rule id="235002" level="0">
    <if_sid>111151</if_sid>
    <description>FortiGate : Silencing forward traffic statistics logs.</description>
  </rule>
  <rule id="235003" level="0">
    <if_sid>111146</if_sid>
    <description>FortiGate : Silencing local traffic logs.</description>
  </rule>

  <!-- Allowed sites -->
  <rule id="235004" level="0">
    <if_sid>111286</if_sid>
    <description>FortiGate : Silencing web filter allowed site logs.</description>
  </rule>
  <rule id="235005" level="0">
    <if_sid>111286</if_sid>
    <description>FortiGate : Silencing IPS passed logs.</description>
  </rule>
  <rule id="235006" level="0">
    <if_sid>111263</if_sid>
    <description>FortiGate : Silencing URL filter allowed logs.</description>
  </rule>

  <!-- Blocked sites - Exclude : none for now
  - Google Play 
  - Icloud
  - from Google Play drops
  -->

</group>